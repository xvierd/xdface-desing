      <code><span class="cm">&lt;!-- Label --&gt;</span>
&lt;<span class="attr">label</span> <span class="attr">class</span>=<span class="str">"xd-label"</span>&gt;Label&lt;/label&gt;

<span class="cm">&lt;!-- Text input --&gt;</span>
&lt;<span class="attr">input</span> <span class="attr">class</span>=<span class="str">"xd-input"</span> <span class="attr">placeholder</span>=<span class="str">"Text input"</span> /&gt;

<span class="cm">&lt;!-- Error state --&gt;</span>
&lt;<span class="attr">input</span> <span class="attr">class</span>=<span class="str">"xd-input xd-input-error"</span> /&gt;
&lt;<span class="attr">span</span> <span class="attr">class</span>=<span class="str">"xd-error-text"</span>&gt;Error message&lt;/span&gt;

<span class="cm">&lt;!-- Helper text --&gt;</span>
&lt;<span class="attr">span</span> <span class="attr">class</span>=<span class="str">"xd-helper"</span>&gt;Helper text&lt;/span&gt;

<span class="cm">&lt;!-- Select --&gt;</span>
&lt;<span class="attr">select</span> <span class="attr">class</span>=<span class="str">"xd-select"</span>&gt;...&lt;/select&gt;

<span class="cm">&lt;!-- Textarea --&gt;</span>
&lt;<span class="attr">textarea</span> <span class="attr">class</span>=<span class="str">"xd-textarea"</span>&gt;&lt;/textarea&gt;

<span class="cm">&lt;!-- Checkbox --&gt;</span>
&lt;<span class="attr">input</span> <span class="attr">type</span>=<span class="str">"checkbox"</span> <span class="attr">class</span>=<span class="str">"xd-checkbox"</span> /&gt;

