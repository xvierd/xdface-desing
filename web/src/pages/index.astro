      <button class="xd-btn-ghost xd-btn-sm xd-code-copy" onclick="copyCode(this)" title="Copy code">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        Copy
      </button>
      <code><span class="cm">// TypeScript</span>
<span class="kw">import</span> &#123; tokens &#125; <span class="kw">from</span> <span class="str">'@xdface/tokens'</span>

<span class="cm">// CSS custom properties</span>
<span class="kw">import</span> <span class="str">'@xdface/tokens/css'</span>

<span class="cm">// Tailwind preset</span>
<span class="kw">const</span> preset = <span class="kw">require</span>(<span class="str">'@xdface/tokens/tailwind'</span>)</code>
    </div>
  </div>

  <div class="grid-3" style="gap:16px;">
    <div class="card" style="overflow:hidden;">
      <div style="padding:14px 18px; background:var(--xd-surface-2); border-bottom:1px solid var(--xd-border);">
